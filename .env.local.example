# Copy to `.env.local` and fill. Never commit `.env.local` — this repo is public.
# Vars are listed per CLAUDE.md; the task that first needs each is noted.

# --- Supabase (Task 1) -------------------------------------------------------
# Provision the project in ap-south (Mumbai) for India — see docs/infra.md.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server only — bypasses RLS, never expose

# --- Claude engines (Task 6+) ------------------------------------------------
ANTHROPIC_API_KEY=

# --- Render (Task 10) — generative provider, vendor-neutral ------------------
# A queue endpoint that takes a prompt and returns a job id. Vendor-neutral —
# the code never names a vendor. Example (fal FLUX Dev):
#   RENDER_API_URL=https://queue.fal.run/fal-ai/flux/dev
#   RENDER_API_AUTH_SCHEME=Key      # fal uses "Key"; others may use "Bearer"
RENDER_API_URL=
RENDER_API_KEY=
RENDER_API_AUTH_SCHEME=Key
RENDER_PROVIDER=generative          # selects GenerativeRenderProvider

# --- Payments (Task 12) ------------------------------------------------------
STRIPE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Hosting / white-label domains (docs/infra.md) ---------------------------
VERCEL_TOKEN=                        # programmatic per-tenant custom domains
VERCEL_PROJECT_ID=

# --- Background jobs (Tasks 5, 9, 10) ----------------------------------------
JOB_QUEUE_URL=
